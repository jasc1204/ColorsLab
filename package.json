{
  "name": "colorslab",
  "private": true,
  "version": "1.0.0",
  "description": "CI linting setup for the Colors lab web app",
  "scripts": {
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint index.html color.html",
    "lint:css": "stylelint css/**/*.css",
    "lint:js": "eslint js/**/*.js"
  },
  "devDependencies": {
    "eslint": "^9.25.0",
    "htmlhint": "^1.1.4",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^36.0.1"
  }
}